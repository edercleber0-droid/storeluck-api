-- ✅ ANTI BUG: Timeout para nao travar
local function withTimeout(callback, timeout)
    local finished = false
    local co = coroutine.create(callback)
    local function check()
        if finished then return end
        if coroutine.status(co) == "dead" then
            finished = true
        else
            task.wait(0.1)
            check()
        end
    end
    task.spawn(check)
    task.wait(timeout)
    if not finished then
        return false
    end
    return true
end

