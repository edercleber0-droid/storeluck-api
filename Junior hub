-- Consulta o Render (seu backend) com retry
local function consultarRender(key, tentativa)
    tentativa = tentativa or 1
    local userId = tostring(player.UserId)
    local url = "https://store-key-system.onrender.com/check?key=" .. key .. "&userId=" .. userId
    
    print("[DEBUG] Consultando (tentativa " .. tentativa .. "): " .. url)
    
    local success, response = pcall(function()
        return game:HttpGet(url, true)
    end)
    
    if not success then
        if tentativa < 3 then
            print("[DEBUG] Erro, tentando novamente em 2 segundos...")
            task.wait(2)
            return consultarRender(key, tentativa + 1)
        end
        print("[DEBUG] Erro de conexao apos 3 tentativas")
        return nil, "Erro de conexao"
    end
    
    print("[DEBUG] Resposta: " .. response)
    
    -- ✅ ANTI BUG: Protecao para JSON invalido
    local decoded
    pcall(function()
        decoded = HttpService:JSONDecode(response)
    end)
    
    if not decoded then
        return nil, "Erro ao processar resposta"
    end
    
    return decoded, nil
end

-- Calcula dias restantes a partir do timestamp
local function calcularDiasRestantes(timestamp)
    if not timestamp then return nil end
    local agora = os.time() * 1000
    local diff = timestamp - agora
    if diff <= 0 then return 0 end
    return math.ceil(diff / (1000 * 60 * 60 * 24))
end

-- Formata timestamp para data legivel
local function formatarData(timestamp)
    if not timestamp then return "Nunca" end
    local segundos = math.floor(timestamp / 1000)
    local sucesso, data = pcall(function()
        return os.date("%d/%m/%Y %H:%M", segundos)
    end)
    if not sucesso then return "Data invalida" end
    return data
end

-- VERIFICA SE KEY EXPIRU
local function verificarSeKeyExpirou(key)
    local data, erro = consultarRender(key)
    
    if erro then
        return false, "Verificando...", nil
    end
    
    if not data then
        return true, "Erro ao validar", nil
    end
    
    print("[DEBUG] Data: valid=" .. tostring(data.valid) .. ", expires=" .. tostring(data.expires))
    
    if not data.valid then
        if data.reason == "used_by_other_user" then
            return true, "KEY JA ESTA SENDO USADA POR OUTRO USUARIO!", nil
        end
        if data.expired then
            return true, "KEY EXPIRADA! (Expirou em " .. formatarData(data.expires) .. ")", data.expires
        end
        return true, "KEY INVALIDA!", nil
    end
    
    if data.expires then
        local diasRestantes = calcularDiasRestantes(data.expires)
        if diasRestantes <= 0 then
            return true, "KEY EXPIRADA! (Expirou em " .. formatarData(data.expires) .. ")", data.expires
        else
            return false, diasRestantes, data.expires
        end
    end
    
    return false, "VITALICIA", nil
end

