-- Substitui TweenService por algo simples
local function simpleTween(obj, props, time)
    local step = 1/30
    local steps = time / step
    local original = {}
    local targets = {}
    
    for prop, value in pairs(props) do
        original[prop] = obj[prop]
        targets[prop] = value
    end
    
    for i = 1, steps do
        local alpha = i / steps
        for prop, target in pairs(targets) do
            local orig = original[prop]
            if type(orig) == "number" and type(target) == "number" then
                obj[prop] = orig + (target - orig) * alpha
            end
        end
        wait(step)
    end
    
    for prop, target in pairs(targets) do
        obj[prop] = target
    end
end

