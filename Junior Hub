local function consultarRender(key)
    local userId = tostring(player.UserId)
    local url = "https://store-key-system.onrender.com/check?key=" .. key .. "&userId=" .. userId
    
    local success, response = pcall(function()
        return game:HttpGet(url, true)
    end)
    
    if not success then
        return nil, "Erro de conexao"
    end
    
    local decoded = HttpService:JSONDecode(response)
    return decoded, nil
end

local function calcularDiasRestantes(timestamp)
    if not timestamp then return nil end
    local agora = os.time() * 1000
    local diff = timestamp - agora
    if diff <= 0 then return 0 end
    return math.ceil(diff / (1000 * 60 * 60 * 24))
end

local function formatarData(timestamp)
    if not timestamp then return "Nunca" end
    local segundos = math.floor(timestamp / 1000)
    return os.date("%d/%m/%Y", segundos)
end

local function verificarSeKeyExpirou(key)
    local data, erro = consultarRender(key)
    
    if erro then
        return false, "Verificando..."
    end
    
    if not data then
        return true, "Erro ao validar"
    end
    
    if not data.valid then
        if data.reason == "used_by_other_user" then
            return true, "KEY JA ESTA SENDO USADA POR OUTRO USUARIO!"
        end
        if data.expired then
            return true, "KEY EXPIRADA! (Expirou em " .. formatarData(data.expires) .. ")"
        end
        return true, "KEY INVALIDA!"
    end
    
    if data.expires then
        local diasRestantes = calcularDiasRestantes(data.expires)
        if diasRestantes <= 0 then
            return true, "KEY EXPIRADA! (Expirou em " .. formatarData(data.expires) .. ")"
        else
            return false, diasRestantes
        end
    end
    
    return false, "VITALICIA"
end

